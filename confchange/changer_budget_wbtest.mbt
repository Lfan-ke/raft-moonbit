///|
/// The changer threads its `MaxInflightBytes` budget into every progress it
/// initializes (etcd's `MakeProgressTracker` (maxInflight, maxBytes)), so a
/// freshly added voter's flow controller carries the configured byte cap.
test "Changer threads MaxInflightBytes into each new progress" {
  let c = Changer::new(max_inflight_bytes=512)
  assert_true(c.simple([("v", "1")]) is None)
  assert_eq(c.prs["1"].inflights.max_bytes(), 512)
}
